{
  "_schema_version": "1.0",
  "_description": "Main configuration file for the rat structural connectome pipeline.",

  "project": {
    "name": "Rat Structural Connectome",
    "author": "Alejandro Aguado",
    "version": "1.0.0",
    "created": "2026-02-05",
    "updated": "2026-03-04"
  },

  "paths": {
    "_comment": "All paths relative to the project root unless marked [absolute].",
    "data_raw":      "data/raw",
    "data_processed": "data/processed",
    "results":       "results",
    "logs":          "logs",
    "source":        "source",
    "scripts":       "scripts",
    "validations":   "validations",
    "config":        "config"
  },

  "atlas": {
    "list_file":  "data/raw/atlas_cg_3d5_list.txt",
    "names_file": "data/raw/atlas_cg_3d5_names.txt",
    "n_rois":     79,
    "matrix_size": 158
  },

  "tractography": {
    "fa_threshold":        0.15,
    "seed_density":        [3, 3, 3],
    "step_size":           0.1,
    "max_streamline_length": 1000,
    "sh_order_max":        6,
    "relative_peak_threshold": 0.7,
    "min_separation_angle": 45
  },

  "connectivity": {
    "fibre_filter_threshold":  0.0,
    "group_mask_fibre_min":   50,
    "group_mask_rat_min":     18,
    "voxel_dimensions_mm":    [2.27273, 2.27273, 10.0],
    "distance_scale_factor":  0.0001
  },

  "groups": {
    "group_1": {
      "label": "t1",
      "description": "Naïve control group",
      "map_prefix": "1"
    },
    "group_2": {
      "label": "t2",
      "description": "Alcohol-exposed group",
      "map_prefix": "2"
    }
  },

  "output": {
    "directory_pattern":  "FA_RN_SI_v0-1_th-{threshold}",
    "filter_name":        "filter_kick_out",
    "save_png_figures":   true,
    "save_3d_figures":    false,
    "figure_resolution":  512
  },

  "logging": {
    "level": "INFO",
    "log_dir": "logs",
    "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
  }
}
